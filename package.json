{
  "name": "rosen-chains",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/abstract-chain",
      "packages/chains/*",
      "packages/networks/*"
    ]
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "npm run clean --workspaces",
    "coverage": "npm run coverage --workspaces",
    "lint": "npm run lint --workspaces",
    "lint:check": "npm run lint:check --workspaces",
    "prepare": "husky install",
    "release": "npm run release --workspaces",
    "test": "npm run test --workspaces",
    "type-check": "npm run type-check --workspaces",
    "version": "npx changeset version && npx changeset add --empty && npm i"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@rosen-bridge/changeset-formatter": "^1.0.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^22.18.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitest/eslint-plugin": "^1.3.9",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-check-file": "^3.2.0",
    "globals": "^16.4.0",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "prettier": "^3.2.4",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
