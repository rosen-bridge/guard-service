{
  "name": "@rosen-chains/doge-blockcypher",
  "version": "0.1.0",
  "description": "A package to be used as network api provider for @rosen-chains/doge package using BlockCypher API",
  "repository": "https://github.com/rosen-bridge/rosen-chains",
  "license": "GPL-3.0",
  "author": "Rosen Team",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "coverage": "npm run test -- --run --coverage",
    "lint": "eslint --fix . && npm run prettify",
    "prettify": "prettier --write . --ignore-path ./.gitignore",
    "release": "npm run test -- --run && npm run build && npm publish --access public",
    "test": "NODE_OPTIONS=--loader=extensionless vitest",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.9",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitest/coverage-istanbul": "^2.1.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "extensionless": "^1.9.6",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@rosen-bridge/abstract-logger": "^2.0.1",
    "@rosen-bridge/json-bigint": "^0.1.0",
    "@rosen-chains/abstract-chain": "^13.0.0",
    "@rosen-chains/doge": "^1.0.0",
    "axios": "^1.6.7",
    "axios-rate-limit": "^1.4.0",
    "bitcoinjs-lib": "^6.1.5"
  }
}
