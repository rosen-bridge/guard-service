{
  "name": "@rosen-chains/ergo",
  "version": "12.1.1",
  "description": "this project contains ergo chain for Rosen-bridge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rosen-bridge/rosen-chains.git",
    "directory": "packages/chains/ergo"
  },
  "license": "MIT",
  "author": "Rosen Team",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "eslint --fix . && npm run prettify",
    "lint:check": "eslint . && npm run prettify:check",
    "prettify": "prettier --write . --ignore-path ../../../.gitignore",
    "prettify:check": "prettier --check . --ignore-path ../../../.gitignore",
    "build": "tsc --build tsconfig.build.json",
    "clean": "rimraf dist && rimraf tsconfig.build.tsbuildinfo",
    "type-check": "tsc --noEmit",
    "test": "NODE_OPTIONS='--import tsx' vitest",
    "coverage": "npm run test -- --run --coverage",
    "release": "npm run test -- --run && npm run clean && npm run build && npm publish --access public"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "^3.1.4",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "@rosen-bridge/abstract-logger": "^2.1.0",
    "@rosen-bridge/ergo-box-selection": "^1.1.3",
    "@rosen-bridge/json-bigint": "^0.2.0",
    "@rosen-bridge/rosen-extractor": "^9.0.0",
    "@rosen-bridge/selection-types": "^0.1.0",
    "@rosen-bridge/tokens": "^3.2.0",
    "@rosen-chains/abstract-chain": "^14.0.1",
    "ergo-lib-wasm-nodejs": "^0.24.1"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "keywords": [
    "rosen"
  ]
}
