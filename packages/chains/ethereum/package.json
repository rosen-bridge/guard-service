    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@rosen-bridge/abstract-logger": "^2.0.1",
    "@rosen-bridge/tokens": "^3.0.0",
